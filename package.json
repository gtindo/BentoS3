{
  "name": "bento-s3",
  "version": "0.1.0",
  "description": "A lightweight S3-compatible API server for local development, automated testing, and CI environments.",
  "type": "module",
  "author": "gtindo",
  "license": "MIT",
  "homepage": "https://github.com/gtindo/bento-s3#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gtindo/bento-s3.git"
  },
  "bugs": {
    "url": "https://github.com/gtindo/bento-s3/issues"
  },
  "keywords": [
    "s3",
    "mock",
    "test",
    "local",
    "storage",
    "aws"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bentos3": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./adapters/node-http": {
      "types": "./dist/adapters/node-http.d.ts",
      "import": "./dist/adapters/node-http.js"
    },
    "./adapters/express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js"
    },
    "./adapters/fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "import": "./dist/adapters/fastify.js"
    },
    "./adapters/fetch": {
      "types": "./dist/adapters/fetch.d.ts",
      "import": "./dist/adapters/fetch.js"
    },
    "./adapters/koa": {
      "types": "./dist/adapters/koa.d.ts",
      "import": "./dist/adapters/koa.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json && node -e \"fs.cpSync('src/dashboard/templates', 'dist/dashboard/templates', { recursive: true }); fs.cpSync('src/dashboard/static', 'dist/dashboard/static', { recursive: true })\"",
    "start": "npm run build && node dist/cli/index.js serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "express": "^5.0.0",
    "fastify": "^5.0.0",
    "koa": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "koa": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "latest",
    "@eslint/js": "latest",
    "@playwright/test": "latest",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/koa": "^3.0.2",
    "@types/node": "latest",
    "eslint": "latest",
    "express": "^5.2.1",
    "fastify": "^5.8.5",
    "koa": "^3.2.0",
    "prettier": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  },
  "dependencies": {
    "ejs": "^5.0.2"
  }
}
