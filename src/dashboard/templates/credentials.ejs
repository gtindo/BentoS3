<%- include('partials/breadcrumbs', { items: [{ label: 'Credentials' }] }) %>
<%- include('partials/page-header', {
  heading: 'Credentials',
  description: 'Create and revoke S3 access keys for local API clients.',
  eyebrow: 'Access',
  actionHref: '/ui/credentials/new',
  actionLabel: 'New credential',
  actionClass: ''
}) %>
<section class="grid stats">
  <article class="stat-card"><span class="stat-label">Total keys</span><span class="stat-value"><%= stats.total %></span></article>
  <article class="stat-card"><span class="stat-label">Enabled</span><span class="stat-value"><%= stats.enabled %></span></article>
  <article class="stat-card"><span class="stat-label">Disabled</span><span class="stat-value"><%= stats.disabled %></span></article>
</section>
<section class="card">
  <div class="panel-title">
    <h2>Access keys</h2>
    <span class="muted"><%= credentials.length %> credentials</span>
  </div>
  <table class="table">
    <thead><tr><th>Access key</th><th>Status</th><th>Created</th><th></th></tr></thead>
    <tbody>
      <% credentials.forEach((credential) => { %>
        <tr>
          <td><span class="name-cell"><span class="resource-icon">K</span><span><%= credential.accessKeyId %></span></span></td>
          <td><%= credential.status %></td>
          <td><%= credential.createdAt %></td>
          <td>
            <form class="inline-form" method="post" action="/ui/credentials/<%= credential.encodedAccessKeyId %>/delete">
              <button class="button danger">Revoke</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
