<%- include('partials/breadcrumbs', { items: [{ label: 'Credentials', href: '/ui/credentials' }, { label: 'New' }] }) %>
<%- include('partials/page-header', {
  heading: 'New credential',
  description: 'Generate an S3 access key for SDK and CLI clients.',
  eyebrow: 'Access',
  actionHref: '',
  actionLabel: '',
  actionClass: ''
}) %>
<div class="card">
  <div class="card-body">
    <form class="stack" method="post" action="/ui/credentials">
      <div class="field">
        <label for="accessKeyId">Access key ID</label>
        <input id="accessKeyId" class="input" name="accessKeyId" placeholder="Access key ID, optional">
        <span class="help">Leave blank to generate a secure access key ID.</span>
      </div>
      <button class="button">Create credential</button>
    </form>
  </div>
</div>
