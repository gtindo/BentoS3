<%- include('partials/breadcrumbs', { items: [{ label: 'Credentials', href: '/ui/credentials' }, { label: 'Created' }] }) %>
<%- include('partials/page-header', {
  heading: 'Credential created',
  description: 'Copy this secret now. It will not be shown again.',
  eyebrow: 'Access',
  actionHref: '/ui/credentials',
  actionLabel: 'Back to credentials',
  actionClass: 'secondary'
}) %>
<div class="card">
  <div class="card-body stack">
    <p><strong>Access key:</strong> <span class="secret"><%= credential.accessKeyId %></span></p>
    <p><strong>Secret:</strong> <span class="secret"><%= credential.secretAccessKey %></span></p>
  </div>
</div>
