<%- include('partials/breadcrumbs', { items: [{ label: 'Buckets', href: '/ui/buckets' }, { label: bucket.name }] }) %>
<%- include('partials/page-header', {
  heading: bucket.name,
  description: 'Browse, upload, download, and remove objects in this bucket.',
  eyebrow: 'Bucket',
  actionHref: `/ui/buckets/${bucket.encodedName}/upload`,
  actionLabel: 'Upload object',
  actionClass: ''
}) %>
<section class="bucket-snapshot">
  <div>
    <p class="eyebrow">Bucket snapshot</p>
    <p class="muted">A flat view of local object inventory.</p>
  </div>
  <div class="summary-list">
    <div class="summary-item">
      <span class="stat-label">Objects</span>
      <span class="stat-value"><%= bucket.objectCount %></span>
    </div>
    <div class="summary-item">
      <span class="stat-label">Stored</span>
      <span class="stat-value"><%= bucket.stored %></span>
    </div>
  </div>
</section>
<section class="card">
  <div class="panel-title">
    <h2>Objects</h2>
    <span class="muted"><%= pagination.startItem %>-<%= pagination.endItem %> of <%= pagination.totalItems %> objects</span>
  </div>
  <% if (objects.length === 0) { %>
    <div class="empty">
      <h3>No objects yet</h3>
      <p>Upload a file-like object to populate this bucket.</p>
    </div>
  <% } else { %>
    <table class="table">
      <thead><tr><th>Key</th><th>Size</th><th>Modified</th><th></th></tr></thead>
      <tbody>
        <% objects.forEach((object) => { %>
          <tr>
            <td><a class="name-cell" data-turbo="false" href="/ui/buckets/<%= bucket.encodedName %>/objects/<%= object.encodedKey %>"><span class="resource-icon file-icon">F</span><span><%= object.key %></span></a></td>
            <td><%= object.size %></td>
            <td><%= object.lastModified %></td>
            <td>
              <form class="inline-form" method="post" action="/ui/buckets/<%= bucket.encodedName %>/objects/<%= object.encodedKey %>/delete">
                <button class="button danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <%- include('partials/pagination', { pagination }) %>
  <% } %>
</section>
